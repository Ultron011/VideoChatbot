# ============================================================
# Token server env. This service ONLY mints LiveKit JWTs, so it
# only needs LiveKit credentials. The OpenAI / HeyGen / ElevenLabs
# keys live in apps/agent/.env (the Python worker reads them there).
# ============================================================

# LiveKit Cloud — https://cloud.livekit.io
# Create a project, then Settings → Keys to copy these three.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Server port (bound to 127.0.0.1; reachable only via the nginx proxy).
PORT=3000

# Optional overrides:
# HOST=127.0.0.1
# ALLOWED_ORIGIN=https://ai-twin.drmalpani.com
