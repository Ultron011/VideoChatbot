# ============================================================
# Python agent worker env. The worker runs the full
# STT -> LLM -> TTS pipeline plus the HeyGen LiveAvatar.
# ============================================================

# LiveKit Cloud — the worker connects here as an agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# HeyGen LiveAvatar — video + lip-sync.
LIVEAVATAR_API_KEY=
# Public sandbox avatar from LiveKit's liveavatar example. Any API key can use it.
# Note: this still consumes account credits (per session-minute). "Public" only
# means "accessible to every key," NOT "free."
# Swap to your DrMalpani custom avatar (be747c9d-8e54-44b3-bcbf-c9b2c4fa1ce7)
# after migrating it to the LiveAvatar dashboard.
LIVEAVATAR_AVATAR_ID=dd73ea75-1218-4ef3-92ce-606d5f7fbc0a

# OpenAI — STT (gpt-4o-transcribe) + LLM (gpt-4o-mini).
OPENAI_API_KEY=

# ElevenLabs — TTS (eleven_turbo_v2_5). Both are required by worker.py.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
