# ============================================================
# Shared per-environment credentials — ONE file for ALL apps.
#
# Copy this to:
#   env/.env.dev    (dev machine)
#   env/.env.prod   (prod box)
# and fill in the values. Both the Node token server and the
# Python agent worker load env/.env.${APP_ENV}.
#
# APP_ENV defaults to "dev" — set `export APP_ENV=prod` once on
# the prod box (e.g. in ~/.bashrc) and never touch env again.
# The real .env.dev / .env.prod files are gitignored.
# ============================================================

# --- LiveKit Cloud — https://cloud.livekit.io ----------------
# Project → Settings → Keys. Used by BOTH the token server
# (to mint JWTs) and the agent worker (to connect as an agent).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- HeyGen LiveAvatar — https://app.liveavatar.com ----------
LIVEAVATAR_API_KEY=
# Public sandbox avatar from LiveKit's liveavatar example. Any API key can use
# it, but it still consumes account credits per session-minute — "public" only
# means "accessible to every key," NOT "free."
# Swap to the DrMalpani custom avatar (be747c9d-8e54-44b3-bcbf-c9b2c4fa1ce7)
# after migrating it to the LiveAvatar dashboard.
LIVEAVATAR_AVATAR_ID=dd73ea75-1218-4ef3-92ce-606d5f7fbc0a

# --- OpenAI — https://platform.openai.com/api-keys -----------
# LLM (gpt-4o-mini) in the agent worker.
OPENAI_API_KEY=

# --- Deepgram — https://console.deepgram.com ------------------
# STT (nova-3, streaming, English+Hindi via language="multi").
DEEPGRAM_API_KEY=

# --- ElevenLabs — https://elevenlabs.io ----------------------
# TTS (eleven_turbo_v2_5). Both required by the agent worker.
# Note: the LiveKit plugin reads ELEVEN_API_KEY (not ELEVENLABS_API_KEY);
# ELEVENLABS_VOICE_ID is read explicitly by worker.py.
ELEVEN_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Agent dispatch -------------------------------------------
# Optional. The worker registers under this name and the token server
# requests it by name for every room. Defaults to ai-twin-${APP_ENV}
# (ai-twin-dev / ai-twin-prod) — set only to override.
# AGENT_NAME=

# --- Token server ---------------------------------------------
# Port the Express token server listens on (loopback only).
PORT=3000
# Prod only: the origin nginx serves the frontend from. Dev doesn't need this —
# the Vite proxy keeps dev same-origin, so CORS never applies locally.
# ALLOWED_ORIGIN=https://ai-twin.drmalpani.com
