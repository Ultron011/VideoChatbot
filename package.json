{
  "name": "ai-twin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/token-server"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/token-server",
    "build": "npm run build -w apps/web",
    "test": "npm run test -w apps/token-server",
    "lint": "npm run lint -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
