# ============================================================
# Node backend env (token endpoint + Vite dev server)
# After the LiveKit Agents migration, this process ONLY needs
# LiveKit credentials. The OpenAI and HeyGen keys live in
# agent/.env (the Python worker reads them there).
# ============================================================

# LiveKit Cloud — https://cloud.livekit.io
# Create a project, then Settings → Keys to copy these three.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Server port
PORT=3000
